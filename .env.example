# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM="ScoreLead <hello@uspostage.io>"
EMAIL_REPLY_TO=hello@uspostage.io
CONTACT_EMAIL=hello@scorelead.io

# Email (waitlist notifications)
NOTIFY_EMAIL=hello@uspostage.io

# Slack (account and plan-subscription alerts)
# Store this only as a server-side secret; never expose it with NEXT_PUBLIC_.
SLACK_WEBHOOK_URL=

# Google Analytics
NEXT_PUBLIC_GA_ID=

# Search indexing. Generate each value independently with:
# openssl rand -hex 16
INDEXNOW_KEY=
INDEXNOW_WEBHOOK_SECRET=
# Override only when running the IndexNow script against a non-production URL.
SCORELEAD_PUBLIC_URL=https://scorelead.io

# Optional public entity profiles. Only add verified ScoreLead-owned URLs.
NEXT_PUBLIC_SCORELEAD_X_URL=https://x.com/scorelead_

# Database (PostgreSQL) - openssl rand -base64 32
DATABASE_URL=

# Auth (better-auth)
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Firecrawl (lead enrichment)
FIRECRAWL_API_KEY=

# Google Maps Places API (lead discovery)
GOOGLE_PLACES_API_KEY=

# Brave Search API (lead enrichment)
BRAVE_SEARCH_API_KEY=

# OpenAI (lead AI extraction & summary)
OPENAI_API_KEY=

# Apollo.io (lead enrichment - email, LinkedIn, company data)
APOLLO_API_KEY=

# Gemini / Nano Banana 2 (social calendar image generation)
GEMINI_API_KEY=

# AWS S3 (image storage: business logos, avatars, content calendar, lead photos)
AWS_REGION=us-east-1
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Optional CDN / custom domain serving the bucket (no trailing slash).
# Leave blank to use the default https://<bucket>.s3.<region>.amazonaws.com URL.
AWS_S3_PUBLIC_BASE_URL=

# Stripe (Pro subscription billing)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Price IDs from the Stripe dashboard (ScoreLead Pro product)
STRIPE_PRO_PRICE_ID=
STRIPE_PRO_ANNUAL_PRICE_ID=
# Background job queue
# Max discovery jobs running at once across the app (default 3)
DISCOVERY_MAX_CONCURRENT=3
# Secret for the /api/jobs/pump cron endpoint (openssl rand -hex 16).
# Vercel Cron sends this automatically as a Bearer token.
CRON_SECRET=

# WhatsApp Business Platform (Meta Embedded Signup + Cloud API)
# Keep false until the integration is ready for customer activation.
NEXT_PUBLIC_WHATSAPP_INTEGRATION_ENABLED=false
META_APP_ID=
META_APP_SECRET=
META_WHATSAPP_CONFIG_ID=
# Pin to a Graph API version supported by your approved Meta app (for example v23.0).
META_GRAPH_API_VERSION=v23.0
# Random value configured identically in Meta's webhook settings.
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
# 32-byte base64 or 64-character hex key: openssl rand -base64 32
WHATSAPP_TOKEN_ENCRYPTION_KEY=
# Concurrent Cloud API sends claimed by each worker (default 3, max 10).
WHATSAPP_MAX_CONCURRENT=3

# Postgres pool size per instance (default 10)
DATABASE_POOL_MAX=10
