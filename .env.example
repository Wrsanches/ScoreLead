# Email (Resend)
RESEND_API_KEY=

# Email (Notify)
NOTIFY_EMAIL=

# Google Analytics
NEXT_PUBLIC_GA_ID=

# Database (PostgreSQL) - openssl rand -base64 32
DATABASE_URL=

# Auth (better-auth)
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Firecrawl (lead enrichment)
FIRECRAWL_API_KEY=

# Google Maps Places API (lead discovery)
GOOGLE_PLACES_API_KEY=

# Brave Search API (lead enrichment)
BRAVE_SEARCH_API_KEY=

# OpenAI (lead AI extraction & summary)
OPENAI_API_KEY=

# Apollo.io (lead enrichment - email, LinkedIn, company data)
APOLLO_API_KEY=

# Gemini / Nano Banana 2 (social calendar image generation)
GEMINI_API_KEY=

# AWS S3 (image storage: business logos, avatars, content calendar, lead photos)
AWS_REGION=us-east-1
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Optional CDN / custom domain serving the bucket (no trailing slash).
# Leave blank to use the default https://<bucket>.s3.<region>.amazonaws.com URL.
AWS_S3_PUBLIC_BASE_URL=

# Stripe (Pro subscription billing)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Price IDs from the Stripe dashboard (ScoreLead Pro product)
STRIPE_PRO_PRICE_ID=
STRIPE_PRO_ANNUAL_PRICE_ID=
# Transactional email sender (verification, password reset)
EMAIL_FROM="ScoreLead <hello@ceramik.app>"

# Background job queue
# Max discovery jobs running at once across the app (default 3)
DISCOVERY_MAX_CONCURRENT=3
# Secret for the /api/jobs/pump cron endpoint (openssl rand -hex 16).
# Vercel Cron sends this automatically as a Bearer token.
CRON_SECRET=

# Postgres pool size per instance (default 10)
DATABASE_POOL_MAX=10
